#!/usr/bin/env bash
# Xelity control panel — run: ai-tool
set -euo pipefail

APP_DIR="${XELITY_DIR:-/opt/xelity}"
ENV_FILE="${APP_DIR}/.env"
SERVICE="xelity"
BRANCH="${XELITY_BRANCH:-main}"

c_title() { printf '\n\033[1;36m══ Xelity ai-tool ══\033[0m\n'; }
c_ok() { printf '\033[32m%s\033[0m\n' "$*"; }
c_warn() { printf '\033[33m%s\033[0m\n' "$*"; }
c_err() { printf '\033[31m%s\033[0m\n' "$*"; }

# Оранжевая плашка на всю ширину терминала (или ~72)
c_banner_orange() {
  local msg="$*"
  local cols=72
  if command -v tput >/dev/null 2>&1; then
    cols=$(tput cols 2>/dev/null || echo 72)
  fi
  [[ "${cols}" -lt 40 ]] && cols=40
  [[ "${cols}" -gt 100 ]] && cols=100
  local pad=$((cols - 2))
  local line
  line=$(printf "%-${pad}s" " ${msg}")
  line=${line:0:${pad}}
  printf '\033[48;5;208m\033[1;30m%s\033[0m\n' "${line}"
}

git_safe() {
  git -c safe.directory="${APP_DIR}" -C "${APP_DIR}" "$@"
}

pkg_version() {
  if [[ -f "${APP_DIR}/package.json" ]]; then
    grep -oE '"version"[[:space:]]*:[[:space:]]*"[^"]+"' "${APP_DIR}/package.json" | head -1 | cut -d'"' -f4 || echo "?"
  else
    echo "?"
  fi
}

# Актуальный tip с GitHub (не доверяем устаревшему origin/main)
# Пишет SHA в REMOTE_TIP; 0 = ок, 1 = ошибка сети/git
REMOTE_TIP=""
REMOTE_CHECK_ERR=""

refresh_remote() {
  REMOTE_TIP=""
  REMOTE_CHECK_ERR=""
  if [[ ! -d "${APP_DIR}/.git" ]]; then
    REMOTE_CHECK_ERR="нет .git"
    return 1
  fi
  git config --global --add safe.directory "${APP_DIR}" 2>/dev/null || true

  # ownership: после chown www-data fetch от root иногда ломается
  chown -R root:root "${APP_DIR}/.git" 2>/dev/null || true

  local out=""
  if command -v timeout >/dev/null 2>&1; then
    out=$(timeout 15 git_safe ls-remote origin "refs/heads/${BRANCH}" 2>/dev/null || true)
  else
    out=$(git_safe ls-remote origin "refs/heads/${BRANCH}" 2>/dev/null || true)
  fi
  REMOTE_TIP=$(printf '%s' "${out}" | awk 'NR==1 {print $1; exit}')
  if [[ -z "${REMOTE_TIP}" || ! "${REMOTE_TIP}" =~ ^[0-9a-f]{7,40}$ ]]; then
    REMOTE_CHECK_ERR="ls-remote не ответил (сеть / доступ к GitHub)"
    # fallback: старый origin/main + fetch
    if command -v timeout >/dev/null 2>&1; then
      timeout 15 git_safe fetch origin "${BRANCH}" --prune --quiet 2>/dev/null || true
    else
      git_safe fetch origin "${BRANCH}" --prune --quiet 2>/dev/null || true
    fi
    REMOTE_TIP=$(git_safe rev-parse "origin/${BRANCH}" 2>/dev/null || echo "")
    if [[ -z "${REMOTE_TIP}" ]]; then
      return 1
    fi
    REMOTE_CHECK_ERR=""
  else
    # подтянуть ref, чтобы пункт 7 / rev-list работали
    git_safe fetch origin "${BRANCH}" --prune --quiet 2>/dev/null || true
  fi
  return 0
}

# Печатает оранжевую строку, если на GitHub есть коммиты впереди
show_update_banner() {
  if [[ ! -d "${APP_DIR}/.git" ]]; then
    return 0
  fi

  local local_sha remote_sha local_short remote_short ver behind
  local_sha=$(git_safe rev-parse HEAD 2>/dev/null || echo "")
  remote_sha="${REMOTE_TIP:-}"
  if [[ -z "${remote_sha}" ]]; then
    remote_sha=$(git_safe rev-parse "origin/${BRANCH}" 2>/dev/null || echo "")
  fi

  if [[ -z "${local_sha}" ]]; then
    return 0
  fi

  ver=$(pkg_version)
  local_short="${local_sha:0:7}"

  if [[ -n "${REMOTE_CHECK_ERR}" && -z "${remote_sha}" ]]; then
    echo
    c_banner_orange "Версия v${ver} · ${local_short} · не удалось проверить GitHub"
    c_banner_orange "${REMOTE_CHECK_ERR} — всё равно можно: пункт 7"
    return 0
  fi

  if [[ -z "${remote_sha}" ]]; then
    echo
    c_banner_orange "Версия v${ver} · ${local_short} · нет данных origin/${BRANCH}"
    return 0
  fi

  remote_short="${remote_sha:0:7}"

  if [[ "${local_sha}" == "${remote_sha}" ]]; then
    echo
    printf '  Версия:  \033[32mv%s\033[0m · %s · актуально (GitHub %s)\n' "${ver}" "${local_short}" "${remote_short}"
    return 0
  fi

  # behind: сколько коммитов на remote, которых нет локально
  behind=$(git_safe rev-list --count "${local_sha}..${remote_sha}" 2>/dev/null || echo "?")

  echo
  c_banner_orange "ДОСТУПНА НОВАЯ ВЕРСИЯ — обнови: пункт 7"
  if [[ "${behind}" != "?" && "${behind}" -gt 0 ]]; then
    c_banner_orange "Сейчас: v${ver} · ${local_short}   →   GitHub: ${remote_short}  (+${behind} комм.)"
  else
    c_banner_orange "Сейчас: v${ver} · ${local_short}   →   GitHub: ${remote_short}"
  fi
}

ask() {
  local prompt="$1"
  local __out
  if [[ -r /dev/tty ]]; then
    read -r -p "${prompt}" __out < /dev/tty
  else
    read -r -p "${prompt}" __out
  fi
  printf '%s' "${__out}"
}

need_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    c_err "Нужен root: sudo ai-tool"
    exit 1
  fi
}

ensure_env() {
  if [[ ! -f "${ENV_FILE}" ]]; then
    mkdir -p "${APP_DIR}"
    cat > "${ENV_FILE}" <<'EOF'
PORT=8088
AITUNNEL_API_KEY=
CORS_ORIGIN=https://xelity.ru,https://www.xelity.ru
EOF
    chmod 600 "${ENV_FILE}"
  fi
}

get_env() {
  local key="$1"
  grep -E "^${key}=" "${ENV_FILE}" 2>/dev/null | head -1 | cut -d= -f2- || true
}

set_env() {
  local key="$1"
  local val="$2"
  ensure_env
  if grep -qE "^${key}=" "${ENV_FILE}"; then
    # escape for sed
    local esc
    esc=$(printf '%s' "${val}" | sed -e 's/[\/&]/\\&/g')
    sed -i "s/^${key}=.*/${key}=${esc}/" "${ENV_FILE}"
  else
    printf '%s=%s\n' "${key}" "${val}" >> "${ENV_FILE}"
  fi
}

mask_key() {
  local k="$1"
  if [[ -z "${k}" ]]; then
    echo "(не задан)"
  elif [[ ${#k} -le 12 ]]; then
    echo "****"
  else
    echo "${k:0:12}…${k: -4}"
  fi
}

show_status() {
  echo
  echo "Каталог:  ${APP_DIR}"
  echo "Порт:     $(get_env PORT)"
  echo "API key:  $(mask_key "$(get_env AITUNNEL_API_KEY)")"
  echo "CORS:     $(get_env CORS_ORIGIN)"
  echo -n "Сервис:   "
  if systemctl is-active --quiet "${SERVICE}" 2>/dev/null; then
    c_ok "active (running)"
  else
    c_warn "$(systemctl is-active "${SERVICE}" 2>/dev/null || echo stopped)"
  fi
  local port
  port=$(get_env PORT)
  port=${port:-8088}
  if curl -fsS -m 3 "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
    c_ok "HTTP :${port} отвечает"
  else
    c_warn "HTTP :${port} не отвечает"
  fi
}

set_api_key() {
  need_root
  ensure_env
  echo
  key=$(ask "Вставь AITUNNEL API ключ (sk-aitunnel-…): ")
  key=$(echo "${key}" | tr -d '[:space:]')
  if [[ -z "${key}" ]]; then
    c_err "Пусто — отмена"
    return
  fi
  if [[ "${key}" != sk-aitunnel-* ]]; then
    c_warn "Ключ обычно начинается с sk-aitunnel-"
    yn=$(ask "Всё равно сохранить? [y/N] ")
    [[ "${yn}" =~ ^[Yy]$ ]] || return
  fi
  set_env AITUNNEL_API_KEY "${key}"
  chmod 600 "${ENV_FILE}"
  chown www-data:www-data "${ENV_FILE}" 2>/dev/null || true
  systemctl restart "${SERVICE}"
  c_ok "Ключ сохранён, сервис перезапущен"
}

set_cors() {
  need_root
  ensure_env
  echo
  echo "Текущий: $(get_env CORS_ORIGIN)"
  val=$(ask "Новый CORS_ORIGIN (через запятую): ")
  val=$(echo "${val}" | xargs)
  [[ -z "${val}" ]] && { c_err "Пусто"; return; }
  set_env CORS_ORIGIN "${val}"
  systemctl restart "${SERVICE}"
  c_ok "CORS обновлён"
}

set_port() {
  need_root
  ensure_env
  echo
  echo "Текущий: $(get_env PORT)"
  val=$(ask "Новый PORT: ")
  val=$(echo "${val}" | tr -d '[:space:]')
  [[ "${val}" =~ ^[0-9]+$ ]] || { c_err "Нужно число"; return; }
  set_env PORT "${val}"
  systemctl restart "${SERVICE}"
  c_ok "Порт ${val}, сервис перезапущен"
  c_warn "Не забудь: ufw allow ${val}/tcp и VITE_API_BASE_URL на Render"
}

do_update() {
  need_root
  bash "${APP_DIR}/deploy/update.sh"
}

test_chat() {
  local port key
  port=$(get_env PORT)
  port=${port:-8088}
  key=$(get_env AITUNNEL_API_KEY)
  if [[ -z "${key}" ]]; then
    c_err "Сначала задай API ключ (пункт меню)"
    return
  fi
  echo
  echo "Тестовый запрос к http://127.0.0.1:${port}/api/chat …"
  local out
  out=$(curl -sS -m 60 -X POST "http://127.0.0.1:${port}/api/chat" \
    -H "Content-Type: application/json" \
    -d '{"modelId":"xlaude-mini-k1","messages":[{"role":"user","content":"Скажи ок одним словом"}]}' || true)
  if echo "${out}" | grep -q '"content"'; then
    c_ok "OK: ${out}"
  else
    c_err "Ошибка: ${out}"
  fi
}

open_logs() {
  need_root
  journalctl -u "${SERVICE}" -n 80 --no-pager || true
  echo
  yn=$(ask "Следить live? [y/N] ")
  if [[ "${yn}" =~ ^[Yy]$ ]]; then
    journalctl -u "${SERVICE}" -f
  fi
}

edit_env() {
  need_root
  ensure_env
  "${EDITOR:-nano}" "${ENV_FILE}"
  systemctl restart "${SERVICE}"
  c_ok "Сохранено и перезапущено"
}

install_firebase_sa() {
  need_root
  local dest="${APP_DIR}/firebase-service-account.json"
  echo
  echo "Firebase Console → Project settings → Service accounts → Generate new private key"
  echo "Скопируй JSON на VPS, затем укажи путь к файлу."
  echo
  local src
  src=$(ask "Путь к JSON на этом сервере (например /root/xelity-sa.json): ")
  src=$(echo "${src}" | xargs)
  if [[ -z "${src}" || ! -f "${src}" ]]; then
    c_err "Файл не найден"
    return
  fi
  if ! grep -q '"private_key"' "${src}"; then
    c_err "Это не похоже на Firebase service account JSON"
    return
  fi
  install -m 600 -o www-data -g www-data "${src}" "${dest}"
  mkdir -p "${APP_DIR}/data"
  chown www-data:www-data "${APP_DIR}/data"
  systemctl restart "${SERVICE}"
  c_ok "Установлен ${dest}, сервис перезапущен"
  echo "Не забудь в Firebase Console → Realtime Database → Rules вставить database.rules.json из репо"
}

menu() {
  while true; do
    c_title
    show_status
    # проверка обновлений при каждом заходе в меню
    refresh_remote || true
    show_update_banner
    echo
    echo "  1) Задать / сменить API ключ"
    echo "  2) CORS (домены фронта)"
    echo "  3) Порт"
    echo "  4) Старт сервиса"
    echo "  5) Стоп сервиса"
    echo "  6) Рестарт"
    echo "  7) Обновить с GitHub"
    echo "  8) Тест чата"
    echo "  9) Логи"
    echo " 10) Открыть .env в редакторе"
    echo " 11) Включить HTTPS (api.xelity.ru) — нужно для сайта на https"
    echo " 12) Firebase Admin (service account) — доверие серверу, не клиенту"
    echo "  0) Выход"
    echo
    choice=$(ask "Выбор: ")
    case "${choice}" in
      1) set_api_key ;;
      2) set_cors ;;
      3) set_port ;;
      4) need_root; systemctl start "${SERVICE}"; c_ok "started" ;;
      5) need_root; systemctl stop "${SERVICE}"; c_ok "stopped" ;;
      6) need_root; systemctl restart "${SERVICE}"; c_ok "restarted" ;;
      7) do_update ;;
      8) test_chat ;;
      9) open_logs ;;
      10) edit_env ;;
      11) need_root; bash "${APP_DIR}/deploy/setup-https.sh" ;;
      12) install_firebase_sa ;;
      0|q|Q) exit 0 ;;
      *) c_warn "Неизвестный пункт" ;;
    esac
    echo
    ask "Enter…" >/dev/null
  done
}

# non-interactive shortcuts: ai-tool status|restart|stop|start|update|check
cmd="${1:-}"
case "${cmd}" in
  "") menu ;;
  status)
    show_status
    refresh_remote || true
    show_update_banner
    ;;
  check)
    refresh_remote || true
    show_update_banner
    ;;
  start) need_root; systemctl start "${SERVICE}"; show_status ;;
  stop) need_root; systemctl stop "${SERVICE}"; show_status ;;
  restart) need_root; systemctl restart "${SERVICE}"; show_status ;;
  update) do_update ;;
  menu) menu ;;
  *)
    echo "Usage: ai-tool [status|check|start|stop|restart|update|menu]"
    exit 1
    ;;
esac
