# --- Client (Vite / Render) ---
# Пусто = тот же origin. На Render: https://api.xelity.ru
VITE_API_BASE_URL=

# --- Backend (VPS) ---
PORT=8088
AITUNNEL_API_KEY=sk-aitunnel-xxx
CORS_ORIGIN=https://xelity.ru,https://www.xelity.ru

# Firebase Admin (обязательно для списания кредитов / бана на сервере)
# Файл предпочтительнее: /opt/xelity/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=/opt/xelity/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=xelity-site
FIREBASE_DATABASE_URL=https://xelity-site-default-rtdb.europe-west1.firebasedatabase.app

# Admin: set users/{yourUid}/isAdmin = true in Firebase Realtime Database Console.
