# --- Client (Vite / Render) ---
# Пусто = тот же origin (локальный vite / VPS all-in-one).
# На Render укажи URL бэкенда на VPS, например https://api.xelity.ru
VITE_API_BASE_URL=

# --- Backend (VPS only) ---
PORT=8088
AITUNNEL_API_KEY=sk-aitunnel-xxx
# Разрешённые origin для CORS (через запятую). Нужно если фронт на Render, API на VPS.
CORS_ORIGIN=https://xelity.ru,https://www.xelity.ru

# Admin: set users/{yourUid}/isAdmin = true in Firebase Realtime Database Console.
# New accounts always get isAdmin: false. Apply database.rules.json in Firebase Console.
